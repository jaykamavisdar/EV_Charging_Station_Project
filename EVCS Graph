    "class GCN_LSTM_Model(nn.Module):\n",
    "\n",
    "    def __init__(self):\n",
    "\n",
    "        super().__init__()\n",
    "\n",
    "        # ---------- GCN ----------\n",
    "\n",
    "        self.gcn1 = GCNConv(7, 32)\n",
    "        self.gcn2 = GCNConv(32, 16)\n",
    "\n",
    "        # ---------- LSTM ----------\n",
    "\n",
    "        self.lstm = nn.LSTM(\n",
    "            input_size=2,      # consumption + registrations\n",
    "            hidden_size=16,\n",
    "            batch_first=True\n",
    "        )\n",
    "\n",
    "        # ---------- Fusion ----------\n",
    "\n",
    "        self.fc1 = nn.Linear(\n",
    "            16 + 16,\n",
    "            32\n",
    "        )\n",
    "\n",
    "        self.fc2 = nn.Linear(\n",
    "            32,\n",
    "            1\n",
    "        )\n",
    "\n",
    "    def forward(\n",
    "        self,\n",
    "        x,\n",
    "        edge_index,\n",
    "        temporal_seq\n",
    "    ):\n",
    "\n",
    "        # -------------------\n",
    "        # GCN\n",
    "        # -------------------\n",
    "\n",
    "        z = self.gcn1(\n",
    "            x,\n",
    "            edge_index\n",
    "        )\n",
    "\n",
    "        z = F.relu(z)\n",
    "\n",
    "        z = self.gcn2(\n",
    "            z,\n",
    "            edge_index\n",
    "        )\n",
    "\n",
    "        # z -> [615,16]\n",
    "\n",
    "        # -------------------\n",
    "        # LSTM\n",
    "        # -------------------\n",
    "\n",
    "        lstm_out, (h_n, c_n) = self.lstm(\n",
    "            temporal_seq\n",
    "        )\n",
    "\n",
    "        h = h_n[-1]\n",
    "\n",
    "        # h -> [615,16]\n",
    "\n",
    "        # -------------------\n",
    "        # Fusion\n",
    "        # -------------------\n",
    "\n",
    "        combined = torch.cat(\n",
    "            [z, h],\n",
    "            dim=1\n",
    "        )\n",
    "\n",
    "        combined = F.relu(\n",
    "            self.fc1(combined)\n",
    "        )\n",
    "\n",
    "        pred = self.fc2(\n",
    "            combined\n",
    "        )\n",
    "\n",
    "        return pred.squeeze()"
   ]
