    "    \"tertiary\"\n",
    "}\n",
    "\n",
    "class TelanganaRoadExtractor(osmium.SimpleHandler):\n",
    "\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.count = 0\n",
    "\n",
    "    def way(self, w):\n",
