    "from sklearn.metrics import (\n",
    "    mean_squared_error,\n",
    "    mean_absolute_error,\n",
    "    r2_score\n",
    ")\n",
    "import numpy as np\n",
    "import torch\n",
    "\n",
    "model.eval()\n",
    "\n",
    "preds = []\n",
    "\n",
    "with torch.no_grad():\n",
    "\n",
    "    for i in range(len(X_test)):\n",
    "\n",
    "        pred = model(\n",
    "            X_tensor,\n",
    "            edge_index_road,   # Road Graph\n",
    "            X_test[i]\n",
    "        )\n",
    "\n",
    "        preds.append(\n",
    "            pred.squeeze().cpu().numpy()\n",
    "        )\n",
    "\n",
    "preds = np.array(preds)\n",
    "y_true = y_test.cpu().numpy()\n",
    "\n",
    "rmse = np.sqrt(\n",
    "    mean_squared_error(\n",
    "        y_true.flatten(),\n",
    "        preds.flatten()\n",
    "    )\n",
    ")\n",
    "\n",
    "mae = mean_absolute_error(\n",
    "    y_true.flatten(),\n",
    "    preds.flatten()\n",
    ")\n",
    "\n",
    "r2 = r2_score(\n",
    "    y_true.flatten(),\n",
    "    preds.flatten()\n",
    ")\n",
    "\n",
    "test_loss = np.mean(\n",
    "    (preds.flatten() - y_true.flatten())**2\n",
    ")\n",
    "\n",
    "print(f\"RMSE : {rmse:.4f}\")\n",
    "print(f\"MAE  : {mae:.4f}\")\n",
    "print(f\"R²   : {r2:.4f}\")\n",
    "print(f\"Test Loss : {test_loss:.4f}\")"
