    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "\n",
    "from torch_geometric.nn import GATv2Conv\n",
    "\n",
    "\n",
    "class GATv2_LSTM_Model(nn.Module):\n",
    "\n",
    "    def __init__(self):\n",
    "\n",
    "        super().__init__()\n",
    "\n",
    "        # -------------------\n",
    "        # GATv2\n",
    "        # -------------------\n",
    "\n",
    "        self.gat1 = GATv2Conv(\n",
    "            in_channels=7,\n",
    "            out_channels=16,\n",
    "            heads=4,\n",
    "            concat=True,\n",
    "            dropout=0.2\n",
    "        )\n",
    "\n",
    "        self.gat2 = GATv2Conv(\n",
    "            in_channels=64,     # 16 × 4 heads\n",
    "            out_channels=16,\n",
    "            heads=1,\n",
    "            concat=False,\n",
    "            dropout=0.2\n",
    "        )\n",
    "\n",
    "        # -------------------\n",
    "        # LSTM\n",
    "        # -------------------\n",
    "\n",
    "        self.lstm = nn.LSTM(\n",
    "            input_size=2,\n",
    "            hidden_size=16,\n",
    "            batch_first=True\n",
    "        )\n",
    "\n",
    "        # -------------------\n",
    "        # Fusion\n",
    "        # -------------------\n",
    "\n",
    "        self.fc1 = nn.Linear(\n",
    "            16 + 16,\n",
    "            32\n",
    "        )\n",
    "\n",
    "        self.dropout = nn.Dropout(0.2)\n",
    "\n",
    "        self.fc2 = nn.Linear(\n",
    "            32,\n",
    "            1\n",
    "        )\n",
    "\n",
    "    def forward(\n",
    "        self,\n",
    "        x,\n",
    "        edge_index,\n",
    "        temporal_seq\n",
    "    ):\n",
    "\n",
    "        # -------------------\n",
    "        # GATv2\n",
    "        # -------------------\n",
    "\n",
    "        z = self.gat1(\n",
    "            x,\n",
    "            edge_index\n",
    "        )\n",
    "\n",
    "        z = F.elu(z)\n",
    "\n",
    "        z = self.gat2(\n",
    "            z,\n",
    "            edge_index\n",
    "        )\n",
    "\n",
    "        z = F.elu(z)\n",
    "\n",
    "        # z -> [615,16]\n",
    "\n",
    "        # -------------------\n",
    "        # LSTM\n",
    "        # -------------------\n",
    "\n",
    "        lstm_out, (h_n, c_n) = self.lstm(\n",
    "            temporal_seq\n",
    "        )\n",
    "\n",
    "        h = h_n[-1]\n",
    "\n",
    "        # h -> [615,16]\n",
    "\n",
    "        # -------------------\n",
    "        # Fusion\n",
    "        # -------------------\n",
    "\n",
    "        combined = torch.cat(\n",
    "            [z, h],\n",
    "            dim=1\n",
    "        )\n",
    "\n",
    "        combined = F.relu(\n",
    "            self.fc1(combined)\n",
    "        )\n",
    "\n",
    "        combined = self.dropout(\n",
    "            combined\n",
    "        )\n",
    "\n",
    "        pred = self.fc2(\n",
    "            combined\n",
    "        )\n",
    "\n",
    "        return pred.squeeze()"
   ]
